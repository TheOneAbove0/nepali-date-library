{
  "name": "@theoneabove0/nepalidatepicker-react",
  "version": "0.1.3",
  "description": "Thin React wrappers for nepalidatepicker datepicker core.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
