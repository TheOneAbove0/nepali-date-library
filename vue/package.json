{
  "name": "nepali-date-library-vue",
  "version": "0.1.0",
  "description": "Thin Vue wrappers for nepali-date-library datepicker core.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "nepali-date-library": "file:../js"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vue": "^3.5.13"
  }
}
